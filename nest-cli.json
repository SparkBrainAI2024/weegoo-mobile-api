{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": ".",
  "sourceRoot": "apps/api/src",
 
  "compilerOptions": {
    "webpack": true
  },

  "projects": {
    "api": {
      "type": "application",
      "root": "apps/api",
      "sourceRoot": "apps/api/src",
      "entryFile": "main",
      "compilerOptions": {
        "tsConfigPath": "apps/api/tsconfig.app.json"
      }
    },
    "admin-api": {
      "type": "application",
      "root": "apps/admin-api",
      "sourceRoot": "apps/admin-api/src",
      "entryFile": "main",
      "compilerOptions": {
        "tsConfigPath": "apps/admin-api/tsconfig.app.json"
      }
    },
    "driver-api": {
      "type": "application",
      "root": "apps/driver-api",
      "entryFile": "main",
      "sourceRoot": "apps/driver-api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/driver-api/tsconfig.app.json"
      }
    },
    "s3": {
      "type": "library",
      "root": "libs/s3",
      "entryFile": "index",
      "sourceRoot": "libs/s3/src",
      "compilerOptions": {
        "tsConfigPath": "libs/s3/tsconfig.lib.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "services": {
      "type": "library",
      "root": "libs/services/auth",
      "entryFile": "index",
      "sourceRoot": "libs/services/auth/src",
      "compilerOptions": {
        "tsConfigPath": "libs/services/auth/tsconfig.lib.json"
      }
    },
    "data-access": {
      "type": "library",
      "root": "libs/data-access",
      "entryFile": "index",
      "sourceRoot": "libs/data-access/src",
      "compilerOptions": {
        "tsConfigPath": "libs/data-access/tsconfig.lib.json"
      }
    },
    "localization": {
      "type": "library",
      "root": "libs/localization",
      "entryFile": "index",
      "sourceRoot": "libs/localization/src",
      "compilerOptions": {
        "tsConfigPath": "libs/localization/tsconfig.lib.json"
      }
    },
    "guards": {
      "type": "library",
      "root": "libs/guards",
      "entryFile": "index",
      "sourceRoot": "libs/guards",
      "compilerOptions": {
        "tsConfigPath": "libs/guards/tsconfig.lib.json"
      }
    },
    "ride-matchmaking": {
      "type": "application",
      "root": "apps/ride-matchmaking",
      "sourceRoot": "apps/ride-matchmaking/src",
      "entryFile": "main",
      "compilerOptions": {
        "tsConfigPath": "apps/ride-matchmaking/src/tsconfig.app.json"
      }
    }
  }
}
