<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Email Verification OTP</title>
    <style>
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            background-color: #f4f6f8;
            margin: 0;
            padding: 0;
            color: #333;
        }

        .email-container {
            max-width: 600px;
            margin: 40px auto;
            background: #ffffff;
            border-radius: 8px;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
            padding: 30px 40px;
        }

        h1 {
            color: #2c3e50;
            font-size: 22px;
            margin-bottom: 20px;
        }

        p {
            font-size: 16px;
            line-height: 1.6;
            margin: 10px 0;
        }

        .otp-box {
            display: inline-block;
            padding: 12px 20px;
            background-color: #007bff;
            color: #ffffff;
            font-size: 24px;
            font-weight: bold;
            border-radius: 6px;
            letter-spacing: 4px;
            margin: 20px 0;
        }

        .footer {
            font-size: 13px;
            color: #888;
            margin-top: 30px;
        }
    </style>
</head>

<body>
    <div class="email-container">
        <h1>Hey {{email}},</h1>
        <p>Please use the OTP below to confirm your email within <strong>5 minutes</strong>.</p>

        <div class="otp-box">{{otp}}</div>

        <p>If you did not request this email, you can safely ignore it.</p>

        <p class="footer">Thanks,<br>The Support Team</p>
    </div>
</body>

</html>