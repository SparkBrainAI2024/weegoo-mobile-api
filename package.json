    "scripts": {
        "prebuild": "rimraf dist",
        "build": "rimraf dist && nest build api  && nest build admin-api && nest build driver-api",
        "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
        "start": "npm run start:api",
        "start:api": "nest start api",
        "start:api:dev": "nest start api --watch",
        "build:api": "nest build api",
        "build:admin-api": "nest build admin-api",
        "build:driver-api": "nest build driver-api",
        "start:admin-api": "nest start admin-api",
        "start:admin-api:dev": "nest start admin-api --watch",
        "start:driver-api": "nest start driver-api",
        "start:driver-api:dev": "nest start driver-api --watch",
        "start:driver-api:prod": "node dist/apps/driver-api/main.js",
        "start:admin-api:prod": "node dist/apps/admin-api/main.js",
        "start:api:prod": "node dist/apps/api/main.js",
        "lint": "eslint \"{apps,libs,test}/**/*.ts\" --fix",
        "test": "jest --config jest.config.js",
        "test:watch": "jest --config jest.config.js --watch",
        "test:cov": "jest --config jest.config.js --coverage",
        "test:api": "jest --config apps/api/jest.config.js",
        "test:admin-api": "jest --config apps/admin-api/jest.config.js",
        "test:driver-api": "jest --config apps/driver-api/jest.config.js"
    },
