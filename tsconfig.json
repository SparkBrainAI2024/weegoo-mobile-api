{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2017",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": false,
    "esModuleInterop": true,

    "paths": {
      "@libs/*": ["libs/*"],
      "@libs/common": ["libs/common"],
      "@libs/common/*": ["libs/common/*"],
      "@libs/data-access": ["libs/data-access"],
      "@libs/data-access/*": ["libs/data-access/*"],
      "@libs/localization": ["libs/localization"],
      "@libs/localization/*": ["libs/localization/*"],
      "@libs/s3": ["libs/s3"],
      "@libs/s3/*": ["libs/s3/*"],
      "@libs/services": ["libs/services"],
      "@libs/services/*": ["libs/services/*"],
      "@libs/services/auth": ["libs/services/auth/src"],
      "@libs/services/auth/*": ["libs/services/auth/src/*"],
      "@libs/services/social-auth": ["libs/services/social-auth/src"],
      "@libs/services/social-auth/*": ["libs/services/social-auth/src/*"],
      "@libs/services/user": ["libs/services/user/src"],
      "@libs/services/user/*": ["libs/services/user/src/*"],
      "@libs/services/rides": ["libs/services/rides/src"],
      "@libs/services/rides/*": ["libs/services/rides/src/*"],
      "@libs/services/mail": ["libs/services/mail"],
      "@libs/services/mail/*": ["libs/services/mail/*"],
      "@libs/services/firebase-messaging": ["libs/services/firebase-messaging/src"],
      "@libs/services/firebase-messaging/*": ["libs/services/firebase-messaging/src/*"],
      "@libs/guards/": ["libs/guards"],
      "@libs/guards/*": ["libs/guards/*"],
      "@api": ["apps/api/src"],
      "@api/*": ["apps/api/src/*"],
      "@admin-api": ["apps/admin-api/src"],
      "@admin-api/*": ["apps/admin-api/src/*"],
      "@driver-api": ["apps/driver-api/src"],
      "@driver-api/*": ["apps/driver-api/src/*"],
      "@libs/services/favourites": ["libs/services/favourites/src"],
      "@libs/services/favourites/*": ["libs/services/favourites/src/*"],
      "@libs/services/notification": ["libs/services/notification/src"],
      "@libs/services/notification/*": ["libs/services/notification/src/*"],
      "@libs/services/ably": ["libs/services/ably/src"],
      "@libs/services/ably/*": ["libs/services/ably/src/*"],
      "@libs/services/profile": ["libs/services/profile/src"],
      "@libs/services/profile/*": ["libs/services/profile/src/*"],
      "@ride-matchmaking": ["apps/ride-matchmaking/src"],
      "@ride-matchmaking/*": ["apps/ride-matchmaking/src/*"],

    },
    "types": ["node", "jest"]
  },
  "exclude": ["node_modules", "dist"]
}
